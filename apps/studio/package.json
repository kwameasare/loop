{
  "name": "@loop/studio",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3001",
    "build": "next build",
    "build:analyze": "ANALYZE=true next build",
    "bundle:budget": "node ./scripts/check-bundle-budget.mjs",
    "typecheck": "tsc --noEmit",
    "typecheck:tests": "tsc -p tsconfig.tests.json --noEmit",
    "start": "next start -p 3001",
    "lint": "next lint",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "format": "prettier --write .",
    "gen:cp-api": "cd ../.. && uv run python tools/gen_cp_api_client.py",
    "gen:cp-api:check": "cd ../.. && uv run python tools/gen_cp_api_client.py --check"
  },
  "dependencies": {
    "@auth0/auth0-react": "2.16.2",
    "@radix-ui/react-dialog": "1.1.15",
    "i18next": "23.16.8",
    "react-i18next": "15.7.4",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "lucide-react": "0.577.0",
    "next": "14.2.35",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "tailwind-merge": "2.6.1"
  },
  "devDependencies": {
    "@next/bundle-analyzer": "14.2.35",
    "@playwright/test": "1.59.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@types/node": "20.19.39",
    "@types/react": "18.3.11",
    "@types/react-dom": "18.3.0",
    "@vitejs/plugin-react": "4.7.0",
    "autoprefixer": "10.5.0",
    "eslint": "8.57.1",
    "eslint-config-next": "14.2.35",
    "jsdom": "25.0.1",
    "postcss": "8.5.14",
    "prettier": "3.8.3",
    "tailwindcss": "3.4.19",
    "typescript": "5.9.3",
    "vitest": "2.1.9"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@9.15.9"
}
