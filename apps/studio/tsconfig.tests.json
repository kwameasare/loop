{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "incremental": false,
    "noUncheckedIndexedAccess": false,
    "types": ["vitest/globals", "@testing-library/jest-dom", "node"]
  },
  "include": [
    "next-env.d.ts",
    "src/**/*.test.ts",
    "src/**/*.test.tsx",
    "e2e/**/*.ts",
    "playwright.config.ts",
    "vitest.config.ts",
    "vitest.setup.ts"
  ],
  "exclude": ["node_modules", ".next"]
}
