exports[`section states > SectionError fires reset on Retry click 1`] = `
<main
  class="container mx-auto flex max-w-3xl flex-col gap-4 p-6"
  data-testid="section-error"
>
  <div
    class="rounded-lg border p-4"
    role="alert"
  >
    <h2
      class="text-base font-medium"
    >
      Inbox
       could not load
    </h2>
    <p
      class="text-muted-foreground mt-1 text-sm"
    >
      The cp-api request failed. Retry, or sign back in if the session expired.
    </p>
    <p
      class="mt-2 text-xs text-muted-foreground"
      data-testid="section-error-request-id"
    >
      request_id: 
      req_123
    </p>
    <div
      class="mt-4 flex items-center gap-2"
    >
      <button
        class="inline-flex items-center justify-center whitespace-nowrap rounded-md text-sm font-medium transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary disabled:pointer-events-none disabled:opacity-50 border border-border bg-background hover:bg-muted h-10 px-4 py-2"
      >
        Retry
      </button>
      <a
        class="text-sm underline underline-offset-2"
        data-testid="section-error-report"
        href="mailto:support@loop.dev?subject=%5BStudio%5D%20Inbox%20load%20failure&body=section%3DInbox%0Arequest_id%3Dreq_123%0Aplease%20include%20what%20you%20were%20doing%20when%20this%20happened"
      >
        Report
      </a>
    </div>
  </div>
</main>
`;

