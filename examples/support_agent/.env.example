# Required: gateway model credentials.
ANTHROPIC_API_KEY=sk-ant-...

# Required: knowledge base id served by your loop-hub MCP server.
SUPPORT_KB_ID=kb_demo_support

# Optional: override the OTel collector.
OTELCOL_ENDPOINT=http://localhost:4318

# Optional: set the deployment environment label that flows into traces.
ENVIRONMENT=local

# Optional: tighten or loosen the per-turn budget the example enforces.
LOOP_MAX_COST_USD=0.10
