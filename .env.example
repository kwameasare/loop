# Loop local-dev environment template.
# Copy to `.env` and adjust as needed. `.env` is gitignored.
#
# This file documents every variable the local stack and the runtime
# read in development. Production config is governed by
# loop_implementation/engineering/ENV_REFERENCE.md.

# ──────────────────────────────────────────────────────────────────────
# docker-compose
# ──────────────────────────────────────────────────────────────────────

# Bind exposed ports to localhost only (default). Set to 0.0.0.0 to make
# the stack reachable from another machine on your LAN.
LOOP_DEV_BIND=127.0.0.1

# Override host-side ports if your machine already has Postgres / Redis
# running on the defaults (Homebrew, another stack, etc.). Container ports
# inside the docker network are unchanged, so service-to-service config
# (LOOP_RUNTIME_DB_URL etc.) keeps working without edits.
#   * Common conflict: Homebrew `postgresql@*` already on 5432.
#     Set LOOP_DEV_POSTGRES_PORT=15432 (and update LOOP_*_DB_URL host port).
#   * Common conflict: Homebrew `redis` already on 6379.
#     Set LOOP_DEV_REDIS_PORT=16379 (and update LOOP_*_REDIS_URL host port).
# LOOP_DEV_POSTGRES_PORT=5432
# LOOP_DEV_REDIS_PORT=6379

# ──────────────────────────────────────────────────────────────────────
# Runtime / data plane
# ──────────────────────────────────────────────────────────────────────

LOOP_RUNTIME_DB_URL=postgresql://loop:loop@localhost:5432/loop
LOOP_RUNTIME_REDIS_URL=redis://localhost:6379/0
LOOP_RUNTIME_QDRANT_URL=http://localhost:6333
LOOP_RUNTIME_NATS_URL=nats://localhost:4222

# Port the dp uvicorn binds locally. Used by tools/dev.sh.
LOOP_RUNTIME_BIND_PORT=8081

# ──────────────────────────────────────────────────────────────────────
# Control plane
# ──────────────────────────────────────────────────────────────────────

LOOP_CP_DB_URL=postgresql://loop:loop@localhost:5432/loop
LOOP_CP_REDIS_URL=redis://localhost:6379/1
LOOP_CP_CLICKHOUSE_URL=http://loop:loop@localhost:8123/loop_telemetry

# Port the cp uvicorn binds locally. Used by tools/dev.sh + studio.
LOOP_CP_API_PORT=8080
LOOP_CP_API_URL=http://localhost:8080

# Local-only HS256 JWT secret. ``tools/seed_dev.py`` mints a JWT signed
# with this; cp-api's HS256Verifier accepts it on /v1/auth/exchange so
# you don't need to stand up Auth0 for local pilots. Use any random
# string >=32 chars (``openssl rand -hex 32``). The cp uvicorn must
# boot with the same value or the exchange returns 401.
#
# In production, swap to RS256/JWKS via LOOP_AUTH_JWKS_URL +
# LOOP_AUTH_ISSUER + LOOP_AUTH_AUDIENCE (see ENV_REFERENCE.md).
LOOP_CP_LOCAL_JWT_SECRET=change-me-32-byte-random-string-please

# Issuer + audience claims the seed-mint script puts on the JWT and
# cp's HS256Verifier matches against. Must agree end-to-end; the
# defaults work for the seed_dev.py flow without further config.
LOOP_CP_AUTH_ISSUER=https://loop.local/
LOOP_CP_AUTH_AUDIENCE=loop-cp

# ──────────────────────────────────────────────────────────────────────
# Studio (Next.js debugger UI)
# ──────────────────────────────────────────────────────────────────────

# Port studio's `next dev` binds. Used by tools/dev.sh.
LOOP_STUDIO_PORT=3001

# ──────────────────────────────────────────────────────────────────────
# Object storage (MinIO in dev; ObjectStore abstraction in prod)
# ──────────────────────────────────────────────────────────────────────

LOOP_OBJSTORE_BACKEND=minio
LOOP_OBJSTORE_ENDPOINT=http://localhost:9000
LOOP_OBJSTORE_ACCESS_KEY=changeme-loop-access-key
# IMPORTANT: rotate this for any environment that ships outside your
# laptop. It's the secret access key for the local MinIO; anyone with
# it can read/write all objects (audit attachments, eval cassettes,
# voice recordings). For prod, use AWS IAM / GCP service accounts /
# Vault-issued credentials and leave this blank.
LOOP_OBJSTORE_SECRET_KEY=changeme-rotate-before-prod
LOOP_OBJSTORE_BUCKET=loop-dev

# ──────────────────────────────────────────────────────────────────────
# Observability
# ──────────────────────────────────────────────────────────────────────

LOOP_OTEL_ENDPOINT=http://localhost:4317
LOOP_OTEL_SAMPLING_RATE=1.0
LOOP_LOG_LEVEL=INFO

# ──────────────────────────────────────────────────────────────────────
# LLM provider keys (leave empty until you need them)
# ──────────────────────────────────────────────────────────────────────
#
# At least one of OPENAI_API_KEY / ANTHROPIC_API_KEY must be set for the
# gateway to route turns to a real LLM. Without one, the runtime starts
# fine but POST /v1/turns returns LOOP-GW-101 (no provider for model).

OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Optional: redis-backed idempotency cache for the gateway. Without
# this, a single-pod local dev uses in-process LRU which is fine for
# pilots. Set this when running multiple gateway pods in a cluster
# so duplicate request_ids are deduped across them.
# LOOP_GATEWAY_REDIS_URL=redis://localhost:6379/2

# ──────────────────────────────────────────────────────────────────────
# Local pilot seed (consumed by `make seed`)
# ──────────────────────────────────────────────────────────────────────
# These default to sane values; override only if you want a different
# workspace / agent name in the seeded data.
# LOOP_DEV_SEED_USER=dev@loop.local
# LOOP_DEV_SEED_WORKSPACE_NAME=Dev Workspace
# LOOP_DEV_SEED_AGENT_NAME=demo-agent
