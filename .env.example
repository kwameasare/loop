# Loop local-dev environment template.
# Copy to `.env` and adjust as needed. `.env` is gitignored.
#
# This file documents every variable the local stack and the runtime
# read in development. Production config is governed by
# loop_implementation/engineering/ENV_REFERENCE.md.

# ──────────────────────────────────────────────────────────────────────
# docker-compose
# ──────────────────────────────────────────────────────────────────────

# Bind exposed ports to localhost only (default). Set to 0.0.0.0 to make
# the stack reachable from another machine on your LAN.
LOOP_DEV_BIND=127.0.0.1

# ──────────────────────────────────────────────────────────────────────
# Runtime / data plane
# ──────────────────────────────────────────────────────────────────────

LOOP_RUNTIME_DB_URL=postgresql://loop:loop@localhost:5432/loop
LOOP_RUNTIME_REDIS_URL=redis://localhost:6379/0
LOOP_RUNTIME_QDRANT_URL=http://localhost:6333
LOOP_RUNTIME_NATS_URL=nats://localhost:4222

# ──────────────────────────────────────────────────────────────────────
# Control plane
# ──────────────────────────────────────────────────────────────────────

LOOP_CP_DB_URL=postgresql://loop:loop@localhost:5432/loop
LOOP_CP_REDIS_URL=redis://localhost:6379/1
LOOP_CP_CLICKHOUSE_URL=http://loop:loop@localhost:8123/loop_telemetry

# ──────────────────────────────────────────────────────────────────────
# Object storage (MinIO in dev; ObjectStore abstraction in prod)
# ──────────────────────────────────────────────────────────────────────

LOOP_OBJSTORE_BACKEND=minio
LOOP_OBJSTORE_ENDPOINT=http://localhost:9000
LOOP_OBJSTORE_ACCESS_KEY=loop
LOOP_OBJSTORE_SECRET_KEY=looploop
LOOP_OBJSTORE_BUCKET=loop-dev

# ──────────────────────────────────────────────────────────────────────
# Observability
# ──────────────────────────────────────────────────────────────────────

LOOP_OTEL_ENDPOINT=http://localhost:4317
LOOP_OTEL_SAMPLING_RATE=1.0
LOOP_LOG_LEVEL=INFO

# ──────────────────────────────────────────────────────────────────────
# LLM provider keys (leave empty until you need them)
# ──────────────────────────────────────────────────────────────────────

OPENAI_API_KEY=
ANTHROPIC_API_KEY=
